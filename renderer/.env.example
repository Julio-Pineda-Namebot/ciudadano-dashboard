# Modo de despliegue del frontend.
NEXT_PUBLIC_APP_MODE=full

# URL del backend REST.
NEXT_PUBLIC_BACKEND_URL=https://your-backend-url.example.com

# Token público de Mapbox (visible en cliente, restringe el origen en el dashboard de Mapbox).
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
