{
  "name": "ciudadano-dashboard",
  "version": "1.0.0",
  "description": "Dashboard para la gestión de ciudadanos",
  "main": "config/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm --dir renderer dev\" \"pnpm electron\"",
    "next": "cd renderer && pnpm dev",
    "electron": "wait-on http://localhost:3000 && electron ."
  },
  "author": "Julio Pineda",
  "license": "MIT",
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/leaflet": "^1.9.21",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "react-leaflet": "^5.0.0"
  }
}
